{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "functionAppName": {
      "type": "string",
      "minLength": 2,
      "maxLength": 60,
      "metadata": {
        "description": "Globally unique name for the Function App. The endpoint will be available at https://<name>.azurewebsites.net/api/certificatesecretproxy."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for all resources. Defaults to the resource group location."
      }
    },
    "appServicePlanSku": {
      "type": "string",
      "defaultValue": "Y1",
      "allowedValues": [
        "Y1",
        "B1",
        "B2",
        "B3",
        "EP1",
        "EP2",
        "EP3"
      ],
      "metadata": {
        "description": "Hosting plan SKU. Y1 = Consumption (serverless, pay-per-call). B1–B3 = Basic dedicated (always-on). EP1–EP3 = Elastic Premium (pre-warmed scale)."
      }
    },
    "workload": {
      "type": "string",
      "defaultValue": "APPSETTINGS",
      "allowedValues": [
        "APPSETTINGS",
        "KEYVAULT",
        "TABLE"
      ],
      "metadata": {
        "description": "Secret backend. APPSETTINGS: secrets are Function App settings (default). KEYVAULT: secrets fetched from Azure Key Vault via managed identity. TABLE: secrets fetched from Azure Table Storage."
      }
    },
    "certRootThumbprint": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "(Optional) Thumbprint of the Root CA certificate uploaded to the Function App → Certificates blade. When set, every incoming client certificate must chain up to this CA. Recommended for managed device fleets."
      }
    },
    "allowedClientCerts": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "(Optional) Semicolon-separated list of allowed client certificate thumbprints (uppercase hex, no spaces). When set, the client cert thumbprint must be in this list. Can be combined with certRootThumbprint."
      }
    },
    "keyVaultName": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "(Required when workload=KEYVAULT) Name of the Azure Key Vault that contains the secrets. After deployment grant the Function App system identity the 'Key Vault Secrets User' role on the vault."
      }
    },
    "tableEndpoint": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "(Required when workload=TABLE) Azure Table Storage URL including the table name. Format: https://<account>.table.core.windows.net/<TableName>. Table rows must have PartitionKey='secret', RowKey=<SecretName>."
      }
    }
  },
  "variables": {
    "storageAccountName": "[concat(toLower(take(replace(replace(parameters('functionAppName'), '-', ''), '_', ''), 11)), uniqueString(resourceGroup().id, parameters('functionAppName')))]",
    "appServicePlanName": "[concat(parameters('functionAppName'), '-plan')]",
    "appInsightsName": "[concat(parameters('functionAppName'), '-insights')]",
    "logAnalyticsName": "[concat(parameters('functionAppName'), '-logs')]",
    "isConsumption": "[equals(parameters('appServicePlanSku'), 'Y1')]",
    "isElasticPremium": "[or(equals(parameters('appServicePlanSku'), 'EP1'), or(equals(parameters('appServicePlanSku'), 'EP2'), equals(parameters('appServicePlanSku'), 'EP3')))]",
    "planTier": "[if(variables('isConsumption'), 'Dynamic', if(variables('isElasticPremium'), 'ElasticPremium', 'Basic'))]",
    "planFamily": "[if(variables('isConsumption'), 'Y', if(variables('isElasticPremium'), 'EP', 'B'))]",
    "storageConnectionString": "[concat('DefaultEndpointsProtocol=https;AccountName=', variables('storageAccountName'), ';EndpointSuffix=', environment().suffixes.storage, ';AccountKey=', listKeys(resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName')), '2022-09-01').keys[0].value)]",
    "websiteLoadCerts": "[if(not(empty(parameters('certRootThumbprint'))), '*', '')]"
  },
  "resources": [
    {
      "type": "Microsoft.Storage/storageAccounts",
      "apiVersion": "2022-09-01",
      "name": "[variables('storageAccountName')]",
      "location": "[parameters('location')]",
      "kind": "StorageV2",
      "sku": {
        "name": "Standard_LRS"
      },
      "properties": {
        "supportsHttpsTrafficOnly": true,
        "minimumTlsVersion": "TLS1_2",
        "allowBlobPublicAccess": false,
        "accessTier": "Hot"
      }
    },
    {
      "type": "Microsoft.OperationalInsights/workspaces",
      "apiVersion": "2022-10-01",
      "name": "[variables('logAnalyticsName')]",
      "location": "[parameters('location')]",
      "properties": {
        "sku": {
          "name": "PerGB2018"
        },
        "retentionInDays": 30,
        "features": {
          "enableLogAccessUsingOnlyResourcePermissions": true
        }
      }
    },
    {
      "type": "Microsoft.Insights/components",
      "apiVersion": "2020-02-02",
      "name": "[variables('appInsightsName')]",
      "location": "[parameters('location')]",
      "kind": "web",
      "dependsOn": [
        "[resourceId('Microsoft.OperationalInsights/workspaces', variables('logAnalyticsName'))]"
      ],
      "properties": {
        "Application_Type": "web",
        "WorkspaceResourceId": "[resourceId('Microsoft.OperationalInsights/workspaces', variables('logAnalyticsName'))]",
        "publicNetworkAccessForIngestion": "Enabled",
        "publicNetworkAccessForQuery": "Enabled",
        "RetentionInDays": 30
      }
    },
    {
      "type": "Microsoft.Web/serverfarms",
      "apiVersion": "2022-09-01",
      "name": "[variables('appServicePlanName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "[parameters('appServicePlanSku')]",
        "tier": "[variables('planTier')]",
        "family": "[variables('planFamily')]",
        "capacity": "[if(variables('isConsumption'), 0, 1)]"
      },
      "kind": "functionapp",
      "properties": {
        "reserved": false
      }
    },
    {
      "type": "Microsoft.Web/sites",
      "apiVersion": "2022-09-01",
      "name": "[parameters('functionAppName')]",
      "location": "[parameters('location')]",
      "kind": "functionapp",
      "dependsOn": [
        "[resourceId('Microsoft.Web/serverfarms', variables('appServicePlanName'))]",
        "[resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName'))]",
        "[resourceId('Microsoft.Insights/components', variables('appInsightsName'))]"
      ],
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', variables('appServicePlanName'))]",
        "clientCertEnabled": true,
        "clientCertMode": "Required",
        "httpsOnly": true,
        "siteConfig": {
          "powerShellVersion": "7.4",
          "ftpsState": "Disabled",
          "minTlsVersion": "1.2",
          "http20Enabled": true,
          "use32BitWorkerProcess": false,
          "appSettings": [
            {
              "name": "AzureWebJobsStorage",
              "value": "[variables('storageConnectionString')]"
            },
            {
              "name": "WEBSITE_CONTENTAZUREFILECONNECTIONSTRING",
              "value": "[variables('storageConnectionString')]"
            },
            {
              "name": "WEBSITE_CONTENTSHARE",
              "value": "[toLower(parameters('functionAppName'))]"
            },
            {
              "name": "FUNCTIONS_EXTENSION_VERSION",
              "value": "~4"
            },
            {
              "name": "FUNCTIONS_WORKER_RUNTIME",
              "value": "powershell"
            },
            {
              "name": "APPLICATIONINSIGHTS_CONNECTION_STRING",
              "value": "[reference(resourceId('Microsoft.Insights/components', variables('appInsightsName')), '2020-02-02').ConnectionString]"
            },
            {
              "name": "APPINSIGHTS_INSTRUMENTATIONKEY",
              "value": "[reference(resourceId('Microsoft.Insights/components', variables('appInsightsName')), '2020-02-02').InstrumentationKey]"
            },
            {
              "name": "WEBSITE_CLIENT_CERT_MODE",
              "value": "Required"
            },
            {
              "name": "WORKLOAD",
              "value": "[parameters('workload')]"
            },
            {
              "name": "CERT_ROOT_THUMBPRINT",
              "value": "[parameters('certRootThumbprint')]"
            },
            {
              "name": "ALLOWED_CLIENT_CERTS",
              "value": "[parameters('allowedClientCerts')]"
            },
            {
              "name": "WEBSITE_LOAD_CERTIFICATES",
              "value": "[variables('websiteLoadCerts')]"
            },
            {
              "name": "KEYVAULT_NAME",
              "value": "[parameters('keyVaultName')]"
            },
            {
              "name": "TABLE_ENDPOINT",
              "value": "[parameters('tableEndpoint')]"
            },
            {
              "name": "POWERSHELL_WORKER_INVOCATION_TIMEOUT_SECS",
              "value": "120"
            }
          ]
        }
      }
    }
  ],
  "outputs": {
    "functionAppName": {
      "type": "string",
      "value": "[parameters('functionAppName')]"
    },
    "functionEndpointUrl": {
      "type": "string",
      "value": "[concat('https://', parameters('functionAppName'), '.azurewebsites.net/api/certificatesecretproxy')]"
    },
    "managedIdentityPrincipalId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Web/sites', parameters('functionAppName')), '2022-09-01', 'Full').identity.principalId]"
    },
    "storageAccountName": {
      "type": "string",
      "value": "[variables('storageAccountName')]"
    },
    "appInsightsConnectionString": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Insights/components', variables('appInsightsName')), '2020-02-02').ConnectionString]"
    }
  }
}
